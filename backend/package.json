{
  "name": "ecommerce-api-scraper",
  "version": "1.0.0",
  "description": "API robusta para scraping de ecommerce com posting automático em social media",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --coverage --detectOpenHandles",
    "test:unit": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=unit",
    "test:integration": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=integration",
    "test:e2e": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern=e2e",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "security:audit": "npm audit --audit-level=moderate && npm audit fix",
    "docker:build": "docker build -t ecommerce-api:latest .",
    "docker:test": "docker run --rm ecommerce-api:latest npm test",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "scraping",
    "ecommerce",
    "social-media",
    "api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.450.0",
    "axios": "^1.6.0",
    "bullmq": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "pg": "^8.11.2",
    "pino": "^8.16.2",
    "pino-http": "^8.5.1",
    "pino-pretty": "^10.3.0",
    "sharp": "^0.32.6",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
