# ====== AMBIENTE ======
NODE_ENV=development
PYTHON_ENV=development
LOG_LEVEL=info

# ====== DATABASE ======
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce_db
DB_USER=ecommerce_user
DB_PASSWORD=${DB_SECURE_PASSWORD}
DB_SSL=require
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?sslmode=require

# ====== REDIS (Message Queue) ======
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=${REDIS_SECURE_PASSWORD}
REDIS_TLS=true

# ====== APIs EXTERNAS ======
WHATSAPP_API_KEY=${WHATSAPP_SECURE_KEY}
WHATSAPP_BUSINESS_ACCOUNT_ID=${WHATSAPP_ACCOUNT_ID}
INSTAGRAM_ACCESS_TOKEN=${INSTAGRAM_SECURE_TOKEN}
INSTAGRAM_BUSINESS_ACCOUNT_ID=${INSTAGRAM_ACCOUNT_ID}

# ====== STORAGE ======
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=${AWS_SECURE_KEY}
AWS_SECRET_ACCESS_KEY=${AWS_SECURE_SECRET}
S3_BUCKET_NAME=ecommerce-products
S3_PUBLIC_URL=https://${S3_BUCKET_NAME}.s3.amazonaws.com

# ====== SEGURANÇA ======
JWT_SECRET=${JWT_SECURE_SECRET}
JWT_EXPIRY=7d
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000
CORS_ORIGIN=https://yourdomain.com

# ====== SCRAPING ======
SCRAPER_TIMEOUT=30
SCRAPER_RETRY_ATTEMPTS=3
SCRAPER_PROXY_URL=${PROXY_URL_IF_NEEDED}
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# ====== MONITORAMENTO ======
SENTRY_DSN=${SENTRY_DSN_URL}
DATADOG_API_KEY=${DATADOG_API_KEY}
